# =========================================================
# CreatorForge AI — Environment Variables
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local or real keys to source control.
# =========================================================

# --- AI providers ---
# Set ANTHROPIC_API_KEY to enable real Claude script generation. Without it,
# the app uses a free offline placeholder engine (no credits charged).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional: override the Claude model (default: claude-opus-4-8).
# e.g. claude-sonnet-4-6 or claude-haiku-4-5 for lower cost/latency.
AI_MODEL=
# Optional: set to "true" to force the placeholder engine even if a key is set.
AI_FORCE_MOCK=

# --- Supabase ---
# Found in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public (browser-exposed) Supabase values. These mirror the two above and
# MUST be prefixed with NEXT_PUBLIC_ so the client bundle can read them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Media providers ---
# Selects which backend powers each media type. Defaults to the built-in
# placeholder engines when unset, so the pipeline works with no keys.
#   voice: "placeholder" (default) | "elevenlabs"
#   image: "placeholder" (default) | "openai"
#   video: "placeholder" (default)
VOICE_PROVIDER=placeholder
IMAGE_PROVIDER=placeholder
VIDEO_PROVIDER=placeholder

# Real voice (ElevenLabs): set VOICE_PROVIDER=elevenlabs and add the key.
# ELEVENLABS_VOICE_ID is an optional default voice (the studio's 5 voices are
# already mapped to ElevenLabs premade voices).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Real images (OpenAI gpt-image-1): set IMAGE_PROVIDER=openai and add
# OPENAI_API_KEY (declared in the AI providers section above).

# Video rendering (Shotstack — composes scenes+voiceover+captions into an MP4).
# "stage" = sandbox (free, for testing), "v1" = production.
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage

# Reserved for future providers:
STABILITY_API_KEY=
REPLICATE_API_TOKEN=

# --- Paddle payments (Track D) ---
# "sandbox" for testing, "production" for live.
PADDLE_ENV=sandbox
# Client-side token (public) — used by Paddle.js for checkout.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Plan price IDs from Paddle Catalog (Sandbox or Live).
NEXT_PUBLIC_PADDLE_PRICE_CREATOR=
NEXT_PUBLIC_PADDLE_PRICE_PRO=
NEXT_PUBLIC_PADDLE_PRICE_AGENCY=
# Server API key (secret) + webhook signing secret (Developer Tools → Notifications).
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Required for the webhook to grant credits (Supabase → Settings → API → service_role). SECRET.
SUPABASE_SERVICE_ROLE_KEY=

# --- Crypto payments (NOWPayments — Track D) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_API_PUBLIC_KEY=
NOWPAYMENTS_IPN_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Phase 6: publishing, admin & notifications ---
# Admin dashboard access (comma-separated emails).
ADMIN_EMAILS=
# Set "true" to enable email notifications (reuses the Resend transport).
NOTIFY_EMAIL=
# Social OAuth — set BOTH id + secret to activate a real provider; otherwise
# the platform runs in placeholder mode (simulated connect + publish).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
